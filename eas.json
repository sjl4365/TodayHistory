{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "apk": {
      "android": {
        "image": "ubuntu-24.04-jdk-17-ndk-r27b",
        "buildType": "apk"
      },
      "env": {
        "NPM_CONFIG_PRODUCTION": "false",
        "YARN_PRODUCTION": "false"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "image": "ubuntu-24.04-jdk-17-ndk-r27b",
        "buildType": "apk",
        "autoIncrement": true
      },
      "env": {
        "NPM_CONFIG_PRODUCTION": "false",
        "YARN_PRODUCTION": "false"
      }
    },
    "production": {
      "android": {
        "image": "ubuntu-24.04-jdk-17-ndk-r27b",
        "buildType": "app-bundle",
        "autoIncrement": true
      },
      "env": {
        "NPM_CONFIG_PRODUCTION": "false",
        "YARN_PRODUCTION": "false"
      }
    },
    "debug-autolinking": {
      "distribution": "internal",
      "android": {
        "image": "ubuntu-24.04-jdk-17-ndk-r27b",
        "buildType": "apk"
      },
      "env": {
        "NPM_CONFIG_PRODUCTION": "false",
        "YARN_PRODUCTION": "false"
      }
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "image": "sdk-54"
      },
      "env": {
        "NPM_CONFIG_PRODUCTION": "false",
        "YARN_PRODUCTION": "false"
      }
    }
  }
}