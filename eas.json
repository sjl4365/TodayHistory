{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "apk": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "NODE_ENV": "production",
        "EXPO_USE_COMMUNITY_AUTOLINKING": "1",
        "NPM_CONFIG_PRODUCTION": "false",
        "YARN_PRODUCTION": "false",
        "EXPO_DEBUG": "1",
        "EXPO_AUTOLINKING_DEBUG": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "env": {
        "NODE_ENV": "production",
        "EXPO_USE_COMMUNITY_AUTOLINKING": "1",
        "NPM_CONFIG_PRODUCTION": "false",
        "YARN_PRODUCTION": "false",
        "EXPO_DEBUG": "1",
        "EXPO_AUTOLINKING_DEBUG": "1"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "NODE_ENV": "production",
        "EXPO_USE_COMMUNITY_AUTOLINKING": "1",
        "NPM_CONFIG_PRODUCTION": "false",
        "YARN_PRODUCTION": "false",
        "EXPO_DEBUG": "1",
        "EXPO_AUTOLINKING_DEBUG": "1"
      },
      "autoIncrement": true
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "NODE_ENV": "development",
        "EXPO_USE_COMMUNITY_AUTOLINKING": "1",
        "NPM_CONFIG_PRODUCTION": "false",
        "YARN_PRODUCTION": "false"
      }
    }
  }
}