{
  "expo": {
    "name": "TodayHistory",
    "slug": "todayhistory",
    "owner": "todayhistory",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "scheme": "todayhistory",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.todayhistory.todayhistory"
    },
    "android": {
      "package": "com.todayhistory.todayhistory",
      "versionCode": 2,
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3506417530430977~9615307190",
          "iosAppId": "ca-app-pub-3506417530430977~8302225521"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8e4bde71-890b-4e6e-a3d3-2241152dc6f4"
      }
    }
  }
}
